{
  "info": {
    "_postman_id": "e8f7c1ff-5f9b-4eb6-9caa-f8f2ddcce4a1",
    "name": "Practice 02 - Products API (Local)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health - GET /",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{apiBase}}/",
          "host": ["{{apiBase}}"],
          "path": [""]
        }
      }
    },
    {
      "name": "List - GET /products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{apiBase}}/products",
          "host": ["{{apiBase}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "Create - POST /products",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.response.to.have.status(201); });",
              "var json = pm.response.json();",
              "pm.test('Has id', function () { pm.expect(json).to.have.property('id'); });",
              "pm.collectionVariables.set('productId', json.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Чайник\",\n  \"price\": 1990\n}"
        },
        "url": {
          "raw": "{{apiBase}}/products",
          "host": ["{{apiBase}}"],
          "path": ["products"]
        }
      }
    },
    {
      "name": "Get By Id - GET /products/:id",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{apiBase}}/products/{{productId}}",
          "host": ["{{apiBase}}"],
          "path": ["products", "{{productId}}"]
        }
      }
    },
    {
      "name": "Update - PUT /products/:id",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Чайник\",\n  \"price\": 2190\n}"
        },
        "url": {
          "raw": "{{apiBase}}/products/{{productId}}",
          "host": ["{{apiBase}}"],
          "path": ["products", "{{productId}}"]
        }
      }
    },
    {
      "name": "Delete - DELETE /products/:id",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{apiBase}}/products/{{productId}}",
          "host": ["{{apiBase}}"],
          "path": ["products", "{{productId}}"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "apiBase",
      "value": "http://localhost:3000"
    },
    {
      "key": "productId",
      "value": "1"
    }
  ]
}
